#include<iostream>
using namespace std;
void swapValues(int* p1, int* p2);
void printArray(int* arr, int size);
int findMax(int* arr, int size);
void reverseArray(int* arr, int size);
int* createArray(int size);
void deleteArray(int* arr);
int main() {
    int size;
    cout<<"Enter size of array: ";
    cin>>size;
    int* myArray = createArray(size);
    cout<<"Enter array elements: ";
    for(int i=0;i<size;i++){
        cin>> * (myArray+i);
    }
    cout<<"\nArray elements:"<<endl;
    printArray(myArray, size);
    cout<<"\nMax value: "<<findMax(myArray, size)<<endl;
    cout<<"\nSwapping two numbers: "<<endl;
    int a=5,b=8;
    cout<<"\nBefore swapping two numbers: "<<endl;
    cout<<"a= "<<a<< "\nb= "<<b<<endl;
    swapValues(&a,&b);
    cout<<"\nAfter swapping two numbers: "<<endl;
    cout<<"a= "<<a<< "\nb= "<<b<<endl;
    cout<<"Reversing array..."<<endl;
    reverseArray(myArray, size);
    cout<<"\nAfter reversing array: "<<endl;
    printArray(myArray, size);
    cout<<"Deleting array..."<<endl;
    deleteArray(myArray);
    myArray=nullptr;
    cout<<"Memory released successfully!"<<endl;
    return 0;
}
void swapValues(int*p1, int*p2){
int temp=*p1;
*p1=*p2;
*p2=temp;
}
void printArray(int* arr, int size){
for(int i=0;i<size;i++){
cout<<*(arr+i)<< " ";}
cout<<endl;
}
int findMax(int* arr, int size){
int maxVal=*arr;
for(int i=0;i<size;i++){
if(*(arr+i)>maxVal){
maxVal=*(arr+i);}
}
return maxVal;}
void reverseArray(int* arr, int size){
int* start=arr;
int* end=arr+size-1;
while(start<end){
swapValues(start,end);
start++;
end--;}
}
int* createArray(int size){
return new int[size];}
void deleteArray(int* arr){
delete []arr;}

