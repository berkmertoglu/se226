import math


def circle_area(radius):
    """Returns area of a circle. Raises ValueError for invalid radius."""
    try:
        if radius <= 0:
            raise ValueError("Radius must be greater than 0.")
        return math.pi * radius ** 2
    except TypeError:
        raise TypeError("Radius must be a number.")


def circle_perimeter(radius):
    """Returns circumference of a circle."""
    return 2 * math.pi * radius


def rectangle_area(width, height):
    """Returns area of a rectangle."""
    return width * height


def rectangle_perimeter(width, height):
    """Returns perimeter of a rectangle."""
    return 2 * (width + height)


def triangle_area(base, height):
    """Returns area of a triangle."""
    return 0.5 * base * height


def main():
    print("Available shapes: circle, rectangle, triangle")
    print("Available calculations: _area, _perimeter (e.g., circle_area)")

    operation = input("Enter the operation you want to perform: ").strip().lower()

    try:
        if operation == "circle_area":
            radius = float(input("Enter radius: "))
            result = circle_area(radius)

        elif operation == "circle_perimeter":
            radius = float(input("Enter radius: "))
            result = circle_perimeter(radius)

        elif operation == "rectangle_area":
            width = float(input("Enter width: "))
            height = float(input("Enter height: "))
            result = rectangle_area(width, height)

        elif operation == "rectangle_perimeter":
            width = float(input("Enter width: "))
            height = float(input("Enter height: "))
            result = rectangle_perimeter(width, height)

        elif operation == "triangle_area":
            base = float(input("Enter base: "))
            height = float(input("Enter height: "))
            result = triangle_area(base, height)

        else:
            print("Invalid operation.")
            return

        print(f"Result: {result:.2f}")

    except ValueError as e:
        print(f"Error: {e}")
    except TypeError as e:
        print(f"Error: {e}")


if __name__ == "__main__":
    main()
